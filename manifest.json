{
  "manifest_version": 3,
  "name": "MIME Filter",
  "version": "1.0.2",
  "description": "Intercept and filter browser downloads by MIME type. Allow or block file types with logging and notifications.",
  "author": "macbuildssys",

  "permissions": [
    "downloads",
    "storage",
    "notifications"
  ],

  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"],
    "type": "module"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "MIME Filter",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "mime-filter@macbuildssys.github.io",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}